<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ handbook.trip_title }} — Wanderlisted</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<style>
/* ─── Reset & Variables ────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --accent: {{ handbook.theme_accent_color }};
  --accent-light: {{ handbook.theme_accent_color }}22;
  --hero-from: {{ handbook.hero_gradient_from }};
  --hero-to: {{ handbook.hero_gradient_to }};
  --safe-green: #16a34a;
  --warning-amber: #d97706;
  --danger-red: #dc2626;
  --radius: 12px;
}
[data-theme="light"] {
  --bg: #f8f7f4;
  --card-bg: #ffffff;
  --text: #1a1a1a;
  --text-muted: #6b7280;
  --border: #e5e5e5;
  --shadow: 0 2px 8px rgba(0,0,0,0.06);
  --shadow-hover: 0 4px 16px rgba(0,0,0,0.10);
  --transit-bg: #f0f9ff;
  --transit-border: #bae6fd;
  --cultural-tip-bg: #fdf4ff;
  --currency-bg: #fffbeb;
  --currency-border: #fde68a;
}
[data-theme="dark"] {
  --bg: #0f0f0f;
  --card-bg: #1a1a1a;
  --text: #e5e5e5;
  --text-muted: #9ca3af;
  --border: #333;
  --shadow: 0 2px 8px rgba(0,0,0,0.3);
  --shadow-hover: 0 4px 20px rgba(0,0,0,0.4);
  --transit-bg: #1e293b;
  --transit-border: #334155;
  --cultural-tip-bg: #2d1f3d;
  --currency-bg: #422006;
  --currency-border: #713f12;
}
body {
  font-family: 'Inter', system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  max-width: 960px;
  margin: 0 auto;
  padding: 0 16px;
}
h1, h2, h3 { font-family: 'Playfair Display', Georgia, serif; }
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ─── Header ───────────────────────────────────────────────────────── */
.hero {
  background: linear-gradient(135deg, var(--hero-from), var(--hero-to));
  color: #fff;
  padding: 48px 32px;
  border-radius: 0 0 var(--radius) var(--radius);
  margin-bottom: 8px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '{{ handbook.hero_emoji }}';
  position: absolute;
  right: 24px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 5rem;
  opacity: 0.15;
  pointer-events: none;
}
/* ─── Theme Toggle ─────────────────────────────────────────────────── */
.theme-toggle {
  position: fixed;
  top: 16px;
  right: 16px;
  z-index: 1000;
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 50%;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 1.1rem;
  box-shadow: var(--shadow);
  transition: background 0.2s, border-color 0.2s;
}
.theme-toggle:hover { box-shadow: var(--shadow-hover); }
.hero h1 { font-size: 2.2rem; margin-bottom: 8px; }
.hero .subtitle { font-size: 1rem; opacity: 0.9; margin-bottom: 16px; }
.hero-pills { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; }
.hero-pill {
  background: rgba(255,255,255,0.2);
  padding: 4px 14px;
  border-radius: 20px;
  font-size: 0.85rem;
  backdrop-filter: blur(4px);
}

/* ─── Safety Banner ────────────────────────────────────────────────── */
.safety-banner {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 20px;
  border-radius: var(--radius);
  margin-bottom: 8px;
  font-size: 0.9rem;
  font-weight: 500;
}
.safety-banner.green  { background: #dcfce7; color: #166534; }
.safety-banner.yellow { background: #fef9c3; color: #854d0e; }
.safety-banner.orange { background: #ffedd5; color: #9a3412; }
.safety-banner.red    { background: #fee2e2; color: #991b1b; }

/* ─── Route Bar ────────────────────────────────────────────────────── */
.route-bar {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 24px;
  margin-bottom: 16px;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 0.9rem;
  box-shadow: var(--shadow);
}
.route-city {
  font-weight: 600;
  background: var(--accent-light);
  color: var(--accent);
  padding: 4px 12px;
  border-radius: 8px;
}
.route-arrow { color: var(--text-muted); font-size: 0.8rem; }

/* ─── Tabs ─────────────────────────────────────────────────────────── */
.tabs-wrapper {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
  margin-bottom: 24px;
}
.tab-list {
  display: flex;
  overflow-x: auto;
  border-bottom: 2px solid var(--border);
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}
.tab-list::-webkit-scrollbar { display: none; }
.tab-btn {
  flex: 0 0 auto;
  padding: 14px 20px;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--text-muted);
  white-space: nowrap;
  transition: color 0.15s, border-color 0.15s;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
}
.tab-btn:hover { color: var(--accent); }
.tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
.tab-btn:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: -2px;
}
.tab-panel { display: none; padding: 28px 24px; }
.tab-panel.active { display: block; }

/* ─── Day Cards ────────────────────────────────────────────────────── */
.day-card {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 20px;
  overflow: hidden;
  transition: box-shadow 0.2s;
}
.day-card:hover { box-shadow: var(--shadow-hover); }
.day-card-header {
  background: var(--accent-light);
  padding: 16px 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}
.day-label { font-weight: 700; font-size: 1.05rem; }
.day-city { color: var(--text-muted); font-size: 0.85rem; }
.weather-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--card-bg);
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.82rem;
  border: 1px solid var(--border);
}
.day-body { padding: 20px; }

/* ─── Time Blocks ──────────────────────────────────────────────────── */
.time-block { margin-bottom: 20px; }
.time-block-label {
  font-weight: 600;
  font-size: 0.88rem;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 10px;
}

/* ─── Activity Card ────────────────────────────────────────────────── */
.activity-card {
  display: flex;
  gap: 14px;
  padding: 12px;
  background: var(--bg);
  border-radius: 8px;
  margin-bottom: 10px;
  border: 1px solid var(--border);
}
.activity-photo {
  width: 110px;
  height: 90px;
  object-fit: cover;
  border-radius: 6px;
  flex-shrink: 0;
  background: var(--border);
}
.activity-info { flex: 1; min-width: 0; }
.activity-info h4 { font-family: 'Inter', sans-serif; font-size: 0.95rem; margin-bottom: 4px; }
.pill {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 6px;
  font-size: 0.75rem;
  font-weight: 500;
  margin-right: 4px;
}
.pill-rating { background: #fef3c7; color: #92400e; }
.pill-price { background: #dbeafe; color: #1e40af; }
.pill-free { background: #dcfce7; color: #166534; }
.activity-meta { font-size: 0.82rem; color: var(--text-muted); margin-top: 4px; }
.activity-links { margin-top: 6px; font-size: 0.82rem; }
.activity-links a { margin-right: 12px; }

/* ─── Transit Panel ────────────────────────────────────────────────── */
.transit-panel {
  background: var(--transit-bg);
  border: 1px solid var(--transit-border);
  border-radius: 8px;
  padding: 12px 16px;
  margin-top: 10px;
  font-size: 0.85rem;
}
.transit-step { display: flex; align-items: center; gap: 8px; padding: 4px 0; }
.transit-icon { font-size: 1rem; width: 24px; text-align: center; }

/* ─── Cultural Tip ─────────────────────────────────────────────────── */
.cultural-tip {
  background: var(--cultural-tip-bg);
  border-left: 3px solid var(--accent);
  padding: 12px 16px;
  border-radius: 0 8px 8px 0;
  margin-top: 12px;
  font-size: 0.88rem;
}

/* ─── Day Footer ───────────────────────────────────────────────────── */
.day-footer {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
  padding: 12px 20px;
  border-top: 1px solid var(--border);
  font-size: 0.85rem;
  color: var(--text-muted);
}

/* ─── Flight Card ──────────────────────────────────────────────────── */
.flight-card {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  margin-bottom: 16px;
  background: var(--bg);
}
.flight-label { font-weight: 700; font-size: 0.9rem; color: var(--accent); margin-bottom: 12px; }
.flight-route {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.flight-point { text-align: center; }
.flight-point .code { font-size: 1.4rem; font-weight: 700; }
.flight-point .time { font-size: 0.85rem; color: var(--text-muted); }
.flight-line {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100px;
}
.flight-line .duration { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 4px; }
.flight-line .bar {
  width: 100%;
  height: 2px;
  background: var(--accent);
  position: relative;
}
.flight-line .bar::after {
  content: '✈';
  position: absolute;
  right: -4px;
  top: -8px;
  font-size: 0.9rem;
}
.flight-line .stops-label { font-size: 0.78rem; color: var(--text-muted); margin-top: 4px; }
.flight-price { font-size: 1.3rem; font-weight: 700; color: var(--accent); margin-top: 12px; }

/* ─── Hotel Card ───────────────────────────────────────────────────── */
.hotel-card {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  margin-bottom: 16px;
  background: var(--bg);
}
.hotel-card h3 { font-family: 'Inter', sans-serif; font-size: 1.05rem; margin-bottom: 4px; }
.hotel-stars { color: #eab308; margin-bottom: 6px; }
.hotel-detail { font-size: 0.88rem; color: var(--text-muted); margin-bottom: 3px; }
.hotel-amenities { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
.amenity-tag {
  background: var(--accent-light);
  color: var(--accent);
  padding: 2px 10px;
  border-radius: 6px;
  font-size: 0.78rem;
}
.hotel-photo {
  width: 100%;
  max-height: 220px;
  object-fit: cover;
  border-radius: var(--radius) var(--radius) 0 0;
  margin: -20px -20px 16px -20px;
  width: calc(100% + 40px);
}
.hotel-photos-row {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
  overflow-x: auto;
  scrollbar-width: thin;
}
.hotel-photos-row img {
  height: 120px;
  border-radius: 6px;
  object-fit: cover;
  flex-shrink: 0;
}
.hotel-map-embed {
  width: 100%;
  height: 200px;
  border: 0;
  border-radius: 8px;
  margin-top: 12px;
}
/* ─── Day Route Map ────────────────────────────────────────────── */
.day-route-map {
  width: 100%;
  height: 260px;
  border: 0;
  border-radius: var(--radius);
  margin-top: 16px;
  margin-bottom: 8px;
}

/* ─── Budget ───────────────────────────────────────────────────────── */
.budget-overview {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 12px;
  margin-bottom: 24px;
}
.budget-stat {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  text-align: center;
}
.budget-stat .value { font-size: 1.5rem; font-weight: 700; color: var(--accent); }
.budget-stat .label { font-size: 0.82rem; color: var(--text-muted); }
.budget-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
.budget-table th, .budget-table td {
  text-align: left;
  padding: 10px 12px;
  border-bottom: 1px solid var(--border);
  font-size: 0.9rem;
}
.budget-table th { font-weight: 600; }
.budget-bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.budget-bar-label { width: 100px; font-size: 0.82rem; text-align: right; }
.budget-bar-track {
  flex: 1;
  height: 18px;
  background: var(--bg);
  border-radius: 9px;
  overflow: hidden;
  border: 1px solid var(--border);
}
.budget-bar-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 9px;
  transition: width 0.3s;
}
.budget-bar-value { width: 80px; font-size: 0.82rem; }

/* ─── Currency Quick Ref ───────────────────────────────────────────── */
.currency-box {
  background: var(--currency-bg);
  border: 1px solid var(--currency-border);
  border-radius: var(--radius);
  padding: 16px 20px;
  font-size: 0.9rem;
}

/* ─── Safety ───────────────────────────────────────────────────────── */
.safety-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  margin-bottom: 16px;
}
.safety-card h3 { font-family: 'Inter', sans-serif; font-size: 1rem; margin-bottom: 8px; }
.emergency-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 8px;
}
.emergency-item {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px;
  text-align: center;
}
.emergency-item .number { font-size: 1.2rem; font-weight: 700; color: var(--accent); }
.emergency-item .label { font-size: 0.78rem; color: var(--text-muted); }

/* ─── Culture ──────────────────────────────────────────────────────── */
.phrase-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
.phrase-table th, .phrase-table td {
  text-align: left;
  padding: 8px 12px;
  border-bottom: 1px solid var(--border);
  font-size: 0.9rem;
}
.phrase-table th { background: var(--accent-light); font-weight: 600; }

/* ─── Packing ──────────────────────────────────────────────────────── */
.packing-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 16px;
}
.packing-category h3 {
  font-family: 'Inter', sans-serif;
  font-size: 0.95rem;
  margin-bottom: 8px;
  color: var(--accent);
}
.packing-item {
  display: flex;
  align-items: baseline;
  gap: 8px;
  padding: 4px 0;
  font-size: 0.88rem;
}
.packing-item .reason { color: var(--text-muted); font-size: 0.78rem; }

/* ─── Footer ───────────────────────────────────────────────────────── */
footer {
  text-align: center;
  padding: 24px;
  color: var(--text-muted);
  font-size: 0.82rem;
  border-top: 1px solid var(--border);
  margin-top: 24px;
}
footer a { margin: 0 8px; }

/* ─── Responsive ───────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .hero { padding: 32px 20px; }
  .hero h1 { font-size: 1.6rem; }
  .tab-btn { padding: 10px 14px; font-size: 0.8rem; }
  .tab-panel { padding: 16px; }
  .activity-card { flex-direction: column; }
  .activity-photo { width: 100%; height: 160px; }
  .flight-route { flex-direction: column; text-align: center; }
}

/* ─── Print ────────────────────────────────────────────────────────── */
@media print {
  body { max-width: none; padding: 0; background: #fff; color: #000; }
  .hero { background: none; color: #000; border: 2px solid #ccc; border-radius: 0; }
  .tab-list { display: none; }
  .tab-panel { display: block !important; padding: 12px 0; }
  .tab-panel::before {
    content: attr(aria-label);
    display: block;
    font-size: 1.3rem;
    font-weight: 700;
    margin: 20px 0 10px;
    border-bottom: 2px solid #333;
    padding-bottom: 4px;
  }
  .day-card { break-inside: avoid; page-break-inside: avoid; }
  .activity-photo { max-width: 80px; max-height: 60px; }
  iframe { display: none; }
  .safety-banner { border: 1px solid; }
  a[href]::after { content: " (" attr(href) ")"; font-size: 0.7rem; color: #666; }
}

/* ─── Accessibility ────────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  * { transition: none !important; animation: none !important; }
}
</style>
</head>
<body>

<!-- ═══ THEME TOGGLE ══════════════════════════════════════════ -->
<button class="theme-toggle" id="theme-toggle" aria-label="Toggle light/dark mode" title="Toggle light/dark mode">🌙</button>

<!-- ═══ HERO HEADER ═══════════════════════════════════════════ -->
<header class="hero">
  <h1>{{ handbook.trip_title or "Your Travel Handbook" }}</h1>
  <p class="subtitle">
    {{ handbook.start_date }}{% if handbook.end_date %} — {{ handbook.end_date }}{% endif %}
    {% if handbook.traveller_names %} · {{ handbook.traveller_names | join(", ") }}{% endif %}
  </p>
  <div class="hero-pills">
    {% if handbook.destinations %}
    <span class="hero-pill">📍 {{ handbook.destinations | join(", ") }}</span>
    {% endif %}
    {% if handbook.travel_style %}
    <span class="hero-pill">💎 {{ handbook.travel_style | title }}</span>
    {% endif %}
    {% if handbook.group_type %}
    <span class="hero-pill">👥 {{ handbook.group_type | title }}</span>
    {% endif %}
    {% if handbook.total_budget_usd %}
    <span class="hero-pill">💰 ${{ "{:,.0f}".format(handbook.total_budget_usd) }} USD</span>
    {% endif %}
    {% if handbook.exchange_rate and handbook.local_currency_code %}
    <span class="hero-pill">💱 $1 = {{ "{:,.2f}".format(handbook.exchange_rate) }} {{ handbook.local_currency_code }}</span>
    {% endif %}
    {% if handbook.safety.languages %}
    <span class="hero-pill">🗣 {{ handbook.safety.languages | join(", ") }}</span>
    {% endif %}
  </div>
</header>

<!-- ═══ SAFETY BANNER ═════════════════════════════════════════ -->
{% if handbook.safety.advisory_summary %}
{% set level = handbook.safety.advisory_level | default("green") %}
<div class="safety-banner {{ level }}" role="alert">
  {% if level == "green" %}🟢{% elif level == "yellow" %}🟡{% elif level == "orange" %}🟠{% else %}🔴{% endif %}
  <span>{{ handbook.safety.advisory_summary }}</span>
  {% if handbook.safety.visa_requirements %}
  <span style="margin-left:auto;font-size:0.82rem">{{ handbook.safety.visa_requirements }}</span>
  {% endif %}
</div>
{% endif %}

<!-- ═══ ROUTE BAR ═════════════════════════════════════════════ -->
{% if handbook.route_cities %}
<div class="route-bar" aria-label="Trip route">
  {% for city in handbook.route_cities %}
  <span class="route-city">{{ city }}</span>
  {% if not loop.last %}
  <span class="route-arrow">
    {% if handbook.route_transport and loop.index0 < handbook.route_transport | length %}
      {% set t = handbook.route_transport[loop.index0] | lower %}
      {% if "flight" in t or "fly" in t %}✈{% elif "train" in t or "shinkansen" in t or "rail" in t %}🚄{% elif "bus" in t %}🚌{% elif "drive" in t or "car" in t %}🚗{% elif "ferry" in t or "boat" in t %}⛴{% else %}→{% endif %}
    {% else %}→{% endif %}
    ──▶
  </span>
  {% endif %}
  {% endfor %}
</div>
{% endif %}

<!-- ═══ TABS ══════════════════════════════════════════════════ -->
<div class="tabs-wrapper">
  <div class="tab-list" role="tablist" aria-label="Handbook sections">
    <button class="tab-btn active" role="tab" aria-selected="true" aria-controls="panel-itinerary" id="tab-itinerary" onclick="switchTab(event, 'itinerary')">📅 Itinerary</button>
    <button class="tab-btn" role="tab" aria-selected="false" aria-controls="panel-flights" id="tab-flights" onclick="switchTab(event, 'flights')">✈ Flights</button>
    <button class="tab-btn" role="tab" aria-selected="false" aria-controls="panel-hotels" id="tab-hotels" onclick="switchTab(event, 'hotels')">🏨 Hotels</button>
    <button class="tab-btn" role="tab" aria-selected="false" aria-controls="panel-budget" id="tab-budget" onclick="switchTab(event, 'budget')">💰 Budget</button>
    <button class="tab-btn" role="tab" aria-selected="false" aria-controls="panel-maps" id="tab-maps" onclick="switchTab(event, 'maps')">🗺 Maps</button>
    <button class="tab-btn" role="tab" aria-selected="false" aria-controls="panel-safety" id="tab-safety" onclick="switchTab(event, 'safety')">🛡 Safety</button>
    <button class="tab-btn" role="tab" aria-selected="false" aria-controls="panel-culture" id="tab-culture" onclick="switchTab(event, 'culture')">🎌 Culture</button>
    <button class="tab-btn" role="tab" aria-selected="false" aria-controls="panel-packing" id="tab-packing" onclick="switchTab(event, 'packing')">🧳 Packing</button>
  </div>

  <!-- ─── TAB 1: ITINERARY ─────────────────────────────────── -->
  <div class="tab-panel active" id="panel-itinerary" role="tabpanel" aria-label="Itinerary" aria-labelledby="tab-itinerary">
    {% if handbook.days %}
    {% set ns = namespace(running_total=0) %}
    {% for day in handbook.days %}
    <div class="day-card">
      <div class="day-card-header">
        <div>
          <span class="day-label">Day {{ day.day_number }}</span>
          {% if day.date %}<span class="day-city"> · {{ day.date }}</span>{% endif %}
          {% if day.city %}<span class="day-city"> · {{ day.city }}</span>{% endif %}
        </div>
        {% if day.weather %}
        <span class="weather-badge">
          {{ day.weather.emoji }} {{ day.weather.temp_low_c | round(0) | int }}–{{ day.weather.temp_high_c | round(0) | int }}°C · {{ day.weather.rain_probability_pct }}% rain
        </span>
        {% endif %}
      </div>
      <div class="day-body">
        {% if day.weather and day.weather.packing_tip %}
        <p style="font-size:0.82rem;color:var(--text-muted);margin-bottom:12px">💡 {{ day.weather.packing_tip }}</p>
        {% endif %}

        {% for block in day.time_blocks %}
        <div class="time-block">
          <div class="time-block-label">
            {% if block.period == "morning" %}🌅 Morning{% elif block.period == "afternoon" %}🌆 Afternoon{% elif block.period == "evening" %}🌙 Evening{% else %}{{ block.period | title }}{% endif %}
          </div>

          {# ── Activities ── #}
          {% for act in block.activities %}
          <div class="activity-card">
            {% if act.photo_urls %}
            <img src="{{ act.photo_urls[0] }}" alt="{{ act.name }}" loading="lazy" class="activity-photo">
            {% endif %}
            <div class="activity-info">
              <h4>{{ act.name }}</h4>
              {% if act.rating %}
              <span class="pill pill-rating">⭐ {{ act.rating }}/5{% if act.review_count %} ({{ "{:,}".format(act.review_count) }}){% endif %}</span>
              {% endif %}
              {% if act.price_level %}
              <span class="pill {% if act.price_level == 'Free' %}pill-free{% else %}pill-price{% endif %}">{{ act.price_level }}</span>
              {% endif %}
              {% if act.estimated_cost_usd %}
              <span class="pill pill-price">~${{ act.estimated_cost_usd | round(0) | int }}</span>
              {% endif %}
              {% if act.description %}
              <p class="activity-meta">{{ act.description[:180] }}</p>
              {% endif %}
              {% if act.opening_hours %}
              <p class="activity-meta">🕐 {{ act.opening_hours[0] }}</p>
              {% endif %}
              <div class="activity-links">
                {% if act.google_maps_url %}<a href="{{ act.google_maps_url }}" target="_blank" rel="noopener">📍 Maps</a>{% endif %}
                {% if act.website_url %}<a href="{{ act.website_url }}" target="_blank" rel="noopener">🌐 Website</a>{% endif %}
              </div>
            </div>
          </div>
          {% endfor %}

          {# ── Restaurant ── #}
          {% if block.restaurant %}
          {% set r = block.restaurant %}
          <div class="activity-card" style="border-left: 3px solid var(--accent)">
            {% if r.photo_urls %}
            <img src="{{ r.photo_urls[0] }}" alt="{{ r.name }}" loading="lazy" class="activity-photo">
            {% endif %}
            <div class="activity-info">
              <h4>🍽 {{ r.name }}</h4>
              {% if r.rating %}
              <span class="pill pill-rating">⭐ {{ r.rating }}/5</span>
              {% endif %}
              {% if r.price_level %}
              <span class="pill pill-price">{{ r.price_level }}</span>
              {% endif %}
              {% if r.estimated_cost_usd %}
              <span class="pill pill-price">~${{ r.estimated_cost_usd | round(0) | int }}/person</span>
              {% endif %}
              {% if r.address %}<p class="activity-meta">📍 {{ r.address }}</p>{% endif %}
              <div class="activity-links">
                {% if r.google_maps_url %}<a href="{{ r.google_maps_url }}" target="_blank" rel="noopener">📍 Maps</a>{% endif %}
                {% if r.website_url %}<a href="{{ r.website_url }}" target="_blank" rel="noopener">🌐 Website</a>{% endif %}
              </div>
            </div>
          </div>
          {% endif %}

          {# ── Transit Steps ── #}
          {% if block.transit %}
          <div class="transit-panel">
            <strong>🚏 Getting Around</strong>
            {% for step in block.transit %}
            <div class="transit-step">
              <span class="transit-icon">{% if step.mode == "walk" %}🚶{% elif step.mode == "transit" %}🚃{% elif step.mode == "drive" %}🚗{% else %}➡{% endif %}</span>
              <span>{{ step.from_place }} → {{ step.to_place }}: {{ step.duration_text }}{% if step.distance_text %} ({{ step.distance_text }}){% endif %}{% if step.transit_line %} <em>[{{ step.transit_line }}]</em>{% endif %}</span>
            </div>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% endfor %}

        {# ── Cultural Tip ── #}
        {% if day.cultural_tip %}
        <div class="cultural-tip">💡 <strong>Cultural Tip:</strong> {{ day.cultural_tip }}</div>
        {% endif %}

        {# ── Day Route Map ── #}
        {% if day.route_map_url %}
        <iframe src="{{ day.route_map_url }}" class="day-route-map" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" title="Day {{ day.day_number }} route map"></iframe>
        {% endif %}
      </div>

      {# ── Day Footer ── #}
      {% set ns.running_total = ns.running_total + day.daily_cost_usd %}
      <div class="day-footer">
        <span>📊 Day cost: ${{ day.daily_cost_usd | round(0) | int }} USD</span>
        {% if day.walking_km %}<span>🚶 {{ day.walking_km | round(1) }} km walked</span>{% endif %}
        <span>📈 Running total: ${{ ns.running_total | round(0) | int }}{% if handbook.total_budget_usd %} / ${{ handbook.total_budget_usd | round(0) | int }}{% endif %}</span>
      </div>
    </div>
    {% endfor %}
    {% else %}
    <p style="color:var(--text-muted)">No day-by-day itinerary available yet. Run a full trip planning request to generate one.</p>
    {% endif %}
  </div>

  <!-- ─── TAB 2: FLIGHTS ────────────────────────────────────── -->
  <div class="tab-panel" id="panel-flights" role="tabpanel" aria-label="Flights & Transport" aria-labelledby="tab-flights">
    {% if handbook.flights %}
    {% for flight in handbook.flights %}
    {% if flight.outbound %}
    <div class="flight-card">
      <div class="flight-label">{% if loop.index == 1 %}OUTBOUND{% else %}FLIGHT {{ loop.index }}{% endif %}</div>
      {% set seg = flight.outbound[0] %}
      {% set last = flight.outbound[-1] %}
      <div class="flight-route">
        <div class="flight-point">
          <div class="code">{{ seg.departure_airport }}</div>
          <div class="time">{{ seg.departure_time }}</div>
        </div>
        <div class="flight-line">
          <div class="duration">{{ seg.flight_number }}{% if seg.duration_minutes %} · {{ (seg.duration_minutes // 60) }}h {{ seg.duration_minutes % 60 }}m{% endif %}</div>
          <div class="bar"></div>
          <div class="stops-label">{% if seg.stops == 0 %}Non-stop{% else %}{{ seg.stops }} stop(s){% endif %} · {{ seg.cabin_class | title }}</div>
        </div>
        <div class="flight-point">
          <div class="code">{{ last.arrival_airport }}</div>
          <div class="time">{{ last.arrival_time }}</div>
        </div>
      </div>
      {% if flight.total_price_usd %}
      <div class="flight-price">${{ "{:,.0f}".format(flight.total_price_usd) }} {{ flight.currency }}</div>
      {% endif %}
    </div>
    {% endif %}

    {% if flight.inbound %}
    <div class="flight-card">
      <div class="flight-label">RETURN</div>
      {% set seg = flight.inbound[0] %}
      {% set last = flight.inbound[-1] %}
      <div class="flight-route">
        <div class="flight-point">
          <div class="code">{{ seg.departure_airport }}</div>
          <div class="time">{{ seg.departure_time }}</div>
        </div>
        <div class="flight-line">
          <div class="duration">{{ seg.flight_number }}{% if seg.duration_minutes %} · {{ (seg.duration_minutes // 60) }}h {{ seg.duration_minutes % 60 }}m{% endif %}</div>
          <div class="bar"></div>
          <div class="stops-label">{% if seg.stops == 0 %}Non-stop{% else %}{{ seg.stops }} stop(s){% endif %}</div>
        </div>
        <div class="flight-point">
          <div class="code">{{ last.arrival_airport }}</div>
          <div class="time">{{ last.arrival_time }}</div>
        </div>
      </div>
    </div>
    {% endif %}
    {% endfor %}
    {% else %}
    <p style="color:var(--text-muted)">No flight data available.</p>
    {% endif %}
  </div>

  <!-- ─── TAB 3: HOTELS ─────────────────────────────────────── -->
  <div class="tab-panel" id="panel-hotels" role="tabpanel" aria-label="Hotels" aria-labelledby="tab-hotels">
    {% if handbook.hotels %}
    {% for hotel in handbook.hotels %}
    <div class="hotel-card">
      {% if hotel.photo_urls %}
      {% if hotel.photo_urls | length == 1 %}
      <img src="{{ hotel.photo_urls[0] }}" alt="{{ hotel.name }}" loading="lazy" class="hotel-photo">
      {% else %}
      <div class="hotel-photos-row">
        {% for photo in hotel.photo_urls[:4] %}
        <img src="{{ photo }}" alt="{{ hotel.name }}" loading="lazy">
        {% endfor %}
      </div>
      {% endif %}
      {% endif %}
      <h3>{{ hotel.name }}</h3>
      {% if hotel.star_rating %}
      <div class="hotel-stars">{{ "★" * hotel.star_rating }}{{ "☆" * (5 - hotel.star_rating) }}</div>
      {% endif %}
      {% if hotel.neighbourhood %}<p class="hotel-detail">📍 {{ hotel.neighbourhood }}</p>{% endif %}
      <p class="hotel-detail">🛏 {{ hotel.room_type }}{% if hotel.bed_type %} · {{ hotel.bed_type }}{% endif %}</p>
      <p class="hotel-detail">📅 {{ hotel.check_in }} → {{ hotel.check_out }}</p>
      {% if hotel.price_per_night_usd %}
      <p class="hotel-detail">💰 ${{ hotel.price_per_night_usd | round(0) | int }}/night · Total: <strong>${{ hotel.total_price_usd | round(0) | int }}</strong></p>
      {% endif %}
      {% if hotel.cancellation_policy %}
      <p class="hotel-detail">📋 {{ hotel.cancellation_policy }}</p>
      {% endif %}
      {% if hotel.amenities %}
      <div class="hotel-amenities">
        {% for a in hotel.amenities %}
        <span class="amenity-tag">{{ a }}</span>
        {% endfor %}
      </div>
      {% endif %}
      {% if hotel.booking_url %}
      <p style="margin-top:10px"><a href="{{ hotel.booking_url }}" target="_blank" rel="noopener">🔗 Book Now</a>
      {% if hotel.google_maps_url %} · <a href="{{ hotel.google_maps_url }}" target="_blank" rel="noopener">📍 Maps</a>{% endif %}
      {% if hotel.website_url %} · <a href="{{ hotel.website_url }}" target="_blank" rel="noopener">🌐 Website</a>{% endif %}
      </p>
      {% elif hotel.google_maps_url or hotel.website_url %}
      <p style="margin-top:10px">
      {% if hotel.google_maps_url %}<a href="{{ hotel.google_maps_url }}" target="_blank" rel="noopener">📍 Maps</a>{% endif %}
      {% if hotel.website_url %} · <a href="{{ hotel.website_url }}" target="_blank" rel="noopener">🌐 Website</a>{% endif %}
      </p>
      {% endif %}
      {% if hotel.description %}
      <p class="hotel-detail" style="margin-top:8px">{{ hotel.description[:200] }}</p>
      {% endif %}
      {% if hotel.map_embed_url %}
      <iframe src="{{ hotel.map_embed_url }}" class="hotel-map-embed" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" title="Map of {{ hotel.name }}"></iframe>
      {% endif %}
    </div>
    {% endfor %}
    {% else %}
    <p style="color:var(--text-muted)">No hotel data available.</p>
    {% endif %}
  </div>

  <!-- ─── TAB 4: BUDGET ─────────────────────────────────────── -->
  <div class="tab-panel" id="panel-budget" role="tabpanel" aria-label="Budget Summary" aria-labelledby="tab-budget">
    <div class="budget-overview">
      <div class="budget-stat">
        <div class="value">${{ "{:,.0f}".format(handbook.budget_total) }}</div>
        <div class="label">Estimated Total</div>
      </div>
      {% if handbook.total_budget_usd %}
      <div class="budget-stat">
        <div class="value">${{ "{:,.0f}".format(handbook.total_budget_usd) }}</div>
        <div class="label">Your Budget</div>
      </div>
      <div class="budget-stat">
        {% set remaining = handbook.total_budget_usd - handbook.budget_total %}
        <div class="value" style="color:{% if remaining >= 0 %}var(--safe-green){% else %}var(--danger-red){% endif %}">
          {% if remaining >= 0 %}${{ "{:,.0f}".format(remaining) }}{% else %}-${{ "{:,.0f}".format(remaining | abs) }}{% endif %}
        </div>
        <div class="label">{% if remaining >= 0 %}Remaining{% else %}Over Budget{% endif %}</div>
      </div>
      {% endif %}
      {% if handbook.budget_per_person %}
      <div class="budget-stat">
        <div class="value">${{ "{:,.0f}".format(handbook.budget_per_person) }}</div>
        <div class="label">Per Person</div>
      </div>
      {% endif %}
    </div>

    <h3 style="margin-bottom:12px">Category Breakdown</h3>
    {% set cats = [
      ("✈ Flights", handbook.budget_flights),
      ("🏨 Hotels", handbook.budget_accommodation),
      ("🍽 Meals", handbook.budget_meals),
      ("🎯 Activities", handbook.budget_activities),
      ("🚃 Transport", handbook.budget_transport),
      ("📦 Misc", handbook.budget_misc)
    ] %}
    {% for label, amount in cats %}
    {% if amount %}
    <div class="budget-bar-row">
      <div class="budget-bar-label">{{ label }}</div>
      <div class="budget-bar-track">
        <div class="budget-bar-fill" style="width: {{ (amount / handbook.budget_total * 100) if handbook.budget_total else 0 }}%"></div>
      </div>
      <div class="budget-bar-value">${{ "{:,.0f}".format(amount) }}</div>
    </div>
    {% endif %}
    {% endfor %}

    {% if handbook.budget_summary %}
    <p style="margin-top:16px;font-size:0.9rem;color:var(--text-muted)">{{ handbook.budget_summary }}</p>
    {% endif %}

    {% if handbook.exchange_rate and handbook.local_currency_code %}
    <div class="currency-box" style="margin-top:20px">
      <strong>💱 Currency Quick Reference</strong><br>
      $1 USD = {{ "{:,.2f}".format(handbook.exchange_rate) }} {{ handbook.local_currency_code }}<br>
      $10 = {{ "{:,.0f}".format(handbook.exchange_rate * 10) }} {{ handbook.local_currency_code }} ·
      $50 = {{ "{:,.0f}".format(handbook.exchange_rate * 50) }} {{ handbook.local_currency_code }} ·
      $100 = {{ "{:,.0f}".format(handbook.exchange_rate * 100) }} {{ handbook.local_currency_code }}
    </div>
    {% endif %}
  </div>

  <!-- ─── TAB 5: MAPS ───────────────────────────────────────── -->
  <div class="tab-panel" id="panel-maps" role="tabpanel" aria-label="Maps & Routes" aria-labelledby="tab-maps">
    {% set map_places = [] %}
    {% for day in handbook.days %}
      {% for block in day.time_blocks %}
        {% for act in block.activities %}
          {% if act.latitude and act.longitude %}
            {% set _ = map_places.append(act) %}
          {% endif %}
        {% endfor %}
      {% endfor %}
    {% endfor %}

    {% if handbook.destinations %}
    {% for dest in handbook.destinations %}
    <div style="margin-bottom:20px">
      <h3 style="margin-bottom:8px">📍 {{ dest | title }}</h3>
      <iframe
        src="https://www.google.com/maps/embed/v1/place?key={{ google_maps_api_key }}&q={{ dest | urlencode }}&zoom=12"
        width="100%" height="350" style="border:0;border-radius:var(--radius)"
        loading="lazy" allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
        title="Map of {{ dest }}">
      </iframe>
    </div>
    {% endfor %}
    {% endif %}

    {# ── Per-Day Route Maps ── #}
    {% set route_days = handbook.days | selectattr('route_map_url') | list %}
    {% if route_days %}
    <h3 style="margin-top:20px;margin-bottom:8px">🚶 Daily Routes</h3>
    {% for day in route_days %}
    {% if day.route_map_url %}
    <div style="margin-bottom:18px">
      <h4>Day {{ day.day_number }}{% if day.title %} — {{ day.title }}{% endif %}</h4>
      <iframe src="{{ day.route_map_url }}" width="100%" height="320"
        style="border:0;border-radius:var(--radius)" loading="lazy" allowfullscreen
        referrerpolicy="no-referrer-when-downgrade"
        title="Day {{ day.day_number }} route"></iframe>
    </div>
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if map_places %}
    <h3 style="margin-top:20px;margin-bottom:8px">📌 All Places</h3>
    <div style="overflow-x:auto">
    <table class="phrase-table">
      <thead><tr><th>Place</th><th>Category</th><th>Rating</th><th>Maps</th></tr></thead>
      <tbody>
      {% for p in map_places %}
      <tr>
        <td>{{ p.name }}</td>
        <td>{{ p.category }}</td>
        <td>{% if p.rating %}⭐ {{ p.rating }}{% else %}—{% endif %}</td>
        <td>{% if p.google_maps_url %}<a href="{{ p.google_maps_url }}" target="_blank" rel="noopener">Open</a>{% endif %}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    </div>
    {% endif %}
  </div>

  <!-- ─── TAB 6: SAFETY ──────────────────────────────────────── -->
  <div class="tab-panel" id="panel-safety" role="tabpanel" aria-label="Safety & Health" aria-labelledby="tab-safety">
    {% if handbook.safety.advisory_summary %}
    <div class="safety-card">
      <h3>Travel Advisory</h3>
      <p>{{ handbook.safety.advisory_summary }}</p>
    </div>
    {% endif %}

    {% if handbook.safety.visa_requirements %}
    <div class="safety-card">
      <h3>📋 Entry Requirements</h3>
      <p>{{ handbook.safety.visa_requirements }}</p>
    </div>
    {% endif %}

    {% if handbook.safety.health_requirements %}
    <div class="safety-card">
      <h3>🏥 Health</h3>
      <ul>
      {% for h in handbook.safety.health_requirements %}
        <li>{{ h }}</li>
      {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if handbook.safety.emergency_numbers %}
    <div class="safety-card">
      <h3>🚨 Emergency Contacts</h3>
      <div class="emergency-grid">
        {% for svc, num in handbook.safety.emergency_numbers.items() %}
        <div class="emergency-item">
          <div class="number">{{ num }}</div>
          <div class="label">{{ svc }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if handbook.safety.seasonal_risks %}
    <div class="safety-card">
      <h3>⚠ Seasonal Risks</h3>
      <ul>
      {% for risk in handbook.safety.seasonal_risks %}
        <li>{{ risk }}</li>
      {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>

  <!-- ─── TAB 7: CULTURE ─────────────────────────────────────── -->
  <div class="tab-panel" id="panel-culture" role="tabpanel" aria-label="Culture & Language" aria-labelledby="tab-culture">
    {% if handbook.culture.phrases %}
    <h3 style="margin-bottom:10px">🗣 Phrasebook</h3>
    <table class="phrase-table">
      <thead>
        <tr><th>English</th><th>Local</th>{% if handbook.culture.phrases[0].get("romanized") %}<th>Romanized</th>{% endif %}</tr>
      </thead>
      <tbody>
      {% for p in handbook.culture.phrases %}
        <tr>
          <td>{{ p.get("english", "") }}</td>
          <td>{{ p.get("local", "") }}</td>
          {% if p.get("romanized") %}<td>{{ p.romanized }}</td>{% endif %}
        </tr>
      {% endfor %}
      </tbody>
    </table>
    {% endif %}

    {% if handbook.culture.etiquette_tips %}
    <h3 style="margin:20px 0 10px">🎎 Etiquette</h3>
    <ul>
    {% for tip in handbook.culture.etiquette_tips %}
      <li style="margin-bottom:4px">{{ tip }}</li>
    {% endfor %}
    </ul>
    {% endif %}

    {% if handbook.culture.tipping_guide %}
    <h3 style="margin:20px 0 10px">💵 Tipping</h3>
    <p>{{ handbook.culture.tipping_guide }}</p>
    {% endif %}

    {% if handbook.culture.dining_customs %}
    <h3 style="margin:20px 0 10px">🍜 Dining Customs</h3>
    <ul>
    {% for dc in handbook.culture.dining_customs %}
      <li style="margin-bottom:4px">{{ dc }}</li>
    {% endfor %}
    </ul>
    {% endif %}

    {% if handbook.culture.dress_code_notes %}
    <h3 style="margin:20px 0 10px">👔 Dress Code</h3>
    <ul>
    {% for d in handbook.culture.dress_code_notes %}
      <li style="margin-bottom:4px">{{ d }}</li>
    {% endfor %}
    </ul>
    {% endif %}
  </div>

  <!-- ─── TAB 8: PACKING ─────────────────────────────────────── -->
  <div class="tab-panel" id="panel-packing" role="tabpanel" aria-label="Packing List" aria-labelledby="tab-packing">
    {% if handbook.packing %}
    {% set categories = {} %}
    {% for item in handbook.packing %}
      {% set cat = item.category or "other" %}
      {% if cat not in categories %}
        {% set _ = categories.update({cat: []}) %}
      {% endif %}
      {% set _ = categories[cat].append(item) %}
    {% endfor %}
    <div class="packing-grid">
      {% for cat, items in categories.items() %}
      <div class="packing-category">
        <h3>{% if cat == "clothing" %}👔{% elif cat == "documents" %}📄{% elif cat == "tech" %}📱{% elif cat == "health" %}💊{% elif cat == "money" %}💴{% elif cat == "activities" %}🎌{% else %}📦{% endif %} {{ cat | title }}</h3>
        {% for item in items %}
        <div class="packing-item">
          <span>{% if item.essential %}☑{% else %}☐{% endif %} {{ item.item }}</span>
          {% if item.reason %}<span class="reason">— {{ item.reason }}</span>{% endif %}
        </div>
        {% endfor %}
      </div>
      {% endfor %}
    </div>
    {% else %}
    <p style="color:var(--text-muted)">No packing list generated yet.</p>
    {% endif %}
  </div>

</div><!-- end tabs-wrapper -->

<!-- ═══ FOOTER ════════════════════════════════════════════════ -->
<footer>
