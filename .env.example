# ── LLM Provider ─────────────────────────────────────────────────────────
# Set LLM_PROVIDER to switch the chat model backend.
# Supported: azure_openai (default), openai, anthropic, google, ollama
LLM_PROVIDER=azure_openai

# Set EMBEDDINGS_PROVIDER to switch the embeddings backend.
# Supported: azure_openai (default), openai
EMBEDDINGS_PROVIDER=azure_openai

# ── Azure OpenAI (required when *_PROVIDER=azure_openai) ────────────────
AZURE_OPENAI_API_KEY=azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=deployment-name
AZURE_OPENAI_API_VERSION=model-api-version
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=embeddings-deployment-name   # 3072 dims (or text-embedding-3-small for 1536 dims)

# ── OpenAI (required when *_PROVIDER=openai) ────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large

# ── Anthropic (required when LLM_PROVIDER=anthropic) ────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Google Gemini (required when LLM_PROVIDER=google) ───────────────────
# GOOGLE_API_KEY=AI...
# GOOGLE_MODEL=gemini-2.0-flash

# ── Ollama / local (required when LLM_PROVIDER=ollama) ──────────────────
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434

# External APIs
OPENWEATHER_API_KEY=openweathermap-api-key
EXCHANGERATE_API_KEY=exchangerate-api-key

# Amadeus (flight & hotel search) — https://developers.amadeus.com
AMADEUS_API_KEY=amadeus-api-key
AMADEUS_API_SECRET=amadeus-api-secret
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Google Maps Platform — https://console.cloud.google.com/apis/credentials
# Enable: Places API (New), Routes API, Maps JavaScript API
GOOGLE_MAPS_API_KEY=google-maps-api-key

# Pinecone — https://app.pinecone.io
PINECONE_API_KEY=pinecone-api-key
PINECONE_INDEX_NAME=wanderlisted-guides
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=langsmith-project-name
LANGCHAIN_API_KEY=langsmith-api-key

# App
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO
