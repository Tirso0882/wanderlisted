# Azure OpenAI
AZURE_OPENAI_API_KEY=azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large   # 3072 dims (or text-embedding-3-small for 1536 dims)

# External APIs
OPENWEATHER_API_KEY=your-openweathermap-api-key
EXCHANGERATE_API_KEY=your-exchangerate-api-key

# Amadeus (flight & hotel search) — https://developers.amadeus.com
AMADEUS_API_KEY=your-amadeus-api-key
AMADEUS_API_SECRET=your-amadeus-api-secret
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Google Maps Platform — https://console.cloud.google.com/apis/credentials
# Enable: Places API (New), Routes API, Maps JavaScript API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Pinecone — https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=wanderlisted-guides
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=wanderlisted-travel-agent
LANGCHAIN_API_KEY=your-langsmith-api-key

# App
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO
